# LLM Configuration
LLM_API_KEY=YOUR_LLM_API_KEY_HERE
LLM_BASE_URL=https://your-openai-compatible-endpoint.example/v1
LLM_MODEL=your-model-id

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Runtime database defaults to CATOWN_HOME/state/catown.db.
# Uncomment only if you need to override it.
# DATABASE_URL=/absolute/path/to/catown.db

# Logging
LOG_LEVEL=INFO
